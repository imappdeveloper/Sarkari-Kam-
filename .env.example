# APP
APP_NAME="SaaS Application"
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost:8000
APP_PORT=8000

# DATABASE
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=saas_db
DB_USERNAME=saas_user
DB_PASSWORD=password

# CACHE & SESSION
BROADCAST_DRIVER=log
CACHE_DRIVER=redis
QUEUE_CONNECTION=sync
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# REDIS
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# MAIL
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@saas.local"
MAIL_FROM_NAME="SaaS Application"

# JWT
JWT_SECRET=your-jwt-secret-key-change-this
JWT_EXPIRATION=60
JWT_REFRESH_EXPIRATION=10080

# STRIPE
STRIPE_PUBLIC_KEY=pk_test_your_public_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_CURRENCY=usd

# FILE UPLOAD
FILE_UPLOAD_MAX_SIZE=10240
FILE_UPLOAD_PATH=uploads
FILESYSTEM_DISK=local

# FRONTEND
VITE_PORT=5173
VITE_API_URL=http://localhost:8000
VITE_APP_URL=http://localhost:5173
